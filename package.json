{
  "name": "esse-agent",
  "version": "2.1.0",
  "description": "Existence Synchronization System Entity — a meta-agent that unifies, coordinates, and fuses multiple AI agents into one smarter system.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:compat": "vitest run tests/compat",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "ai-agent",
    "llm",
    "multi-agent",
    "orchestration",
    "fusion",
    "esse",
    "gpt",
    "claude",
    "openai",
    "meta-agent"
  ],
  "author": "ESSE AI <hi@vvvesse.xyz> (http://vvvesse.xyz/)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/esse-ai/esse-agent.git"
  },
  "homepage": "http://vvvesse.xyz/",
  "bugs": {
    "url": "https://github.com/esse-ai/esse-agent/issues"
  },
  "dependencies": {
    "openai": "^4.28.0",
    "@anthropic-ai/sdk": "^0.20.1",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/uuid": "^9.0.7",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
