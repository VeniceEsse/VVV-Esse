# ESSE Agent — Environment Variables
# Copy this file to .env and fill in your values

# ─── LLM Provider ─────────────────────────────────────
# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Default model
ESSE_MODEL=gpt-4o
ESSE_PROVIDER=openai

# ─── ESSE Config ──────────────────────────────────────
ESSE_MAX_AGENTS=5
ESSE_SHARED_MEMORY=true
ESSE_DEBUG=false

# ─── Memory Backend (optional) ────────────────────────
# Leave blank to use in-memory store (default)
# PINECONE_API_KEY=
# PINECONE_INDEX=esse-memory
